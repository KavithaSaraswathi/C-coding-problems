#include <stdio.h>

int main(){
    int i,n,low,high,mid,k,found=0;
    int arr[100];
    printf("Enter number of values:");
    scanf("%d",&n);
    
    for(i=0;i<n;i++){
        printf("Enter value %d:",i+1);
        scanf("%d",&arr[i]);
    }
    
    printf("Enter value to be searched:");
    scanf("%d",&k);
    low=0;
    high=n-1;
    mid=(low+high)/2;
    
    while(high>=low){
        if(arr[mid]==k){
            found=1;
            printf("Value found");
            break;
        }
        else if(arr[mid]>k){
            high=mid-1;
        }
        else{
            low=mid+1;
        }
    }
    if(found==0){
        printf("Value not found");
    }
    return 0;
}
