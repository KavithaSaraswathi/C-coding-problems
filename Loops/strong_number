#include <stdio.h>

int main() {
    int n, temp, sum = 0;

    scanf("%d", &n);

    temp = n;

    while(temp != 0) {
        int a = temp % 10;
        int fact = 1;

        for(int i = 1; i <= a; i++)
            fact *= i;

        sum += fact;
        temp /= 10;
    }

    if(sum == n)
        printf("Strong");
    else
        printf("Not Strong");

    return 0;
}
