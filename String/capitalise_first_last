#include <stdio.h>
#include <string.h>
#include <ctype.h>

int main() {
    char str[100];

    scanf(" %[^\n]", str);

    int len = strlen(str);

    if(str[0] != ' ')
        str[0] = toupper(str[0]);

    if(str[len-1] != ' ')
        str[len-1] = toupper(str[len-1]);

    for(int i = 0; str[i] != '\0'; i++) {
        if(str[i]==' ' && str[i+1]!=' ')
            str[i+1] = toupper(str[i+1]);

        if(str[i]!=' ' && str[i+1]==' ')
            str[i] = toupper(str[i]);
    }

    printf("%s", str);

    return 0;
}
