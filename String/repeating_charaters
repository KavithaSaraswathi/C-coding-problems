#include <stdio.h>

int main() {
    char str[100];

    scanf(" %[^\n]", str);

    for(int i = 0; str[i] != '\0'; i++) {
        int count = 1;

        if(str[i] == '0')
            continue;

        for(int j = i+1; str[j] != '\0'; j++) {
            if(str[i] == str[j]) {
                count++;
                str[j] = '0';
            }
        }

        if(count > 1)
            printf("%c\n", str[i]);
    }

    return 0;
}
