#include <stdio.h>
#include <ctype.h>

int main() {
    char str[200];
    int mark[26] = {0};

    fgets(str, 200, stdin);

    for(int i = 0; str[i]; i++) {
        if(isalpha(str[i])) {
            char ch = tolower(str[i]);
            mark[ch - 'a'] = 1;
        }
    }

    for(int i = 0; i < 26; i++) {
        if(mark[i] == 0) {
            printf("Not Pangram");
            return 0;
        }
    }

    printf("Pangram");

    return 0;
}
