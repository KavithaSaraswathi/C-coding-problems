#include <stdio.h>

int main(){
    int i,n;
    int arr[100];
    int max1=arr[0],max2=arr[0];

    printf("Enter number of elements:");
    scanf("%d",&n);
    for(i=0;i<n;i++){
        printf("Enter the value %d:",i+1);
        scanf("%d",&arr[i]);
    }
    for(i=0;i<n;i++){
        if(max1<arr[i]){
            max2=max1;
            max1=arr[i];
        }
        else if(max2<arr[i] && arr[i]!=max1){
            max2=arr[i];
        }
    }
    printf("Second maximum element is %d",max2);
    return 0;
}
