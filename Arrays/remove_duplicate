#include <stdio.h>

int main(){
    int i,j=0,n;
    int arr[100];
    printf("Enter number of values:");
    scanf("%d",&n);
  
    for(i=0;i<n;i++){
        printf("Enter value %d:",i+1);
        scanf("%d",&arr[i]);
    }
  
    for(i=1;i<n;i++){
        if(arr[i]!=arr[j]){
            j++;
            arr[j]=arr[i];
        }
    }
  
    for(i=0;i<=j;i++){
        printf("%d\n",arr[i]);
    }
    return 0;
}
