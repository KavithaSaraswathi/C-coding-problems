#include <stdio.h>

int main(){
    int i,n,temp;
    int arr[100];
    int low=0,mid=0;
    

    printf("Enter number of elements:");
    scanf("%d",&n);
    for(i=0;i<n;i++){
        printf("Enter the value %d:",i+1);
        scanf("%d",&arr[i]);
    }
    int high=n-1;
    while(high>=mid){
        if(arr[mid]==0){
            temp=arr[low];
            arr[low]=arr[mid];
            arr[mid]=temp;
            low++;
            mid++;
        }
        else if(arr[mid]==1){
            mid++;
        }
        else{
            temp=arr[high];
            arr[high]=arr[mid];
            arr[mid]=temp;
            high--;
        }
    }
    for(i=0;i<n;i++){
        printf("%d  ",arr[i]);
    
    }
    return 0;
}
