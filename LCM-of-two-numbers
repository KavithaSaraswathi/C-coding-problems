#include<stdio.h>
int main(){
    int i,a,b,temp,temp1,x,y,lcm;
    printf("Enter two numbers:");
    scanf("%d %d",&a,&b);
    x=a;
    y=b;
    
    if(b>a){
        temp=b;
        b=a;
        a=temp;
    }
    while(b!=0){
        temp1=a%b;
        a=b;
        b=temp1;
    }

    lcm=(x*y)/a;

    printf("The LCM of the two numbers is %d",lcm);
    return 0;


}
