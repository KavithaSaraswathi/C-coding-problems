#include <stdio.h>

int main() {
    int a[10], n, ce = 0, co = 0;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    for (int i = 0; i < n; i++) {
        scanf("%d", &a[i]);
    }

    for (int i = 0; i < n; i++) {
        if (a[i] % 2 == 0)
            ce++;
        else
            co++;
    }

    printf("Even = %d\nOdd = %d", ce, co);

    return 0;
}
